<?php
session_start();

if (!isset($_SESSION['history'])) {
    $_SESSION['history'] = [];
}

$result = "";
$tableHtml = "";
$gpa = null;
$interpretation = "";
$studentName = "";
$semester = "";

if ($_SERVER['REQUEST_METHOD'] === 'POST') {
    $studentName = trim($_POST['student_name'] ?? '');
    $semester = trim($_POST['semester'] ?? '');
    $courses = $_POST['course'] ?? [];
    $credits = $_POST['credits'] ?? [];
    $grades = $_POST['grade'] ?? [];

    $totalPoints = 0;
    $totalCredits = 0;
    $seenCourses = [];

    $tableHtml = "<table class='table table-bordered mt-3'>";
    $tableHtml .= "<thead class='thead-dark'>
                    <tr>
                        <th>Course</th>
                        <th>Credits</th>
                        <th>Grade</th>
                        <th>Grade Points</th>
                    </tr>
                   </thead><tbody>";

    for ($i = 0; $i < count($courses); $i++) {
        $course = trim($courses[$i]);
        $cr = floatval($credits[$i]);
        $g = floatval($grades[$i]);

        if ($course === '' || $cr <= 0) {
            continue;
        }

        if (in_array(strtolower($course), $seenCourses)) {
            continue;
        }

        $seenCourses[] = strtolower($course);

        $safeCourse = htmlspecialchars($course);
        $pts = $cr * $g;
        $totalPoints += $pts;
        $totalCredits += $cr;

        $tableHtml .= "<tr>
                        <td>$safeCourse</td>
                        <td>$cr</td>
                        <td>$g</td>
                        <td>$pts</td>
                       </tr>";
    }

    $tableHtml .= "</tbody></table>";

    if ($totalCredits > 0) {
        $gpa = $totalPoints / $totalCredits;

        if ($gpa >= 3.7) {
            $interpretation = "Distinction";
        } elseif ($gpa >= 3.0) {
            $interpretation = "Merit";
        } elseif ($gpa >= 2.0) {
            $interpretation = "Pass";
        } else {
            $interpretation = "Fail";
        }

        $result = "Student: " . htmlspecialchars($studentName) .
                  " | Semester: " . htmlspecialchars($semester) .
                  " | GPA: " . number_format($gpa, 2) .
                  " ($interpretation)";

        $_SESSION['history'][] = [
            'student_name' => $studentName,
            'semester' => $semester,
            'gpa' => number_format($gpa, 2),
            'interpretation' => $interpretation,
            'time' => date('Y-m-d H:i:s')
        ];
    } else {
        $result = "No valid courses entered.";
    }
}
?>
